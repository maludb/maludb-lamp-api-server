RewriteEngine On

# Pass the Authorization header through to PHP (some SAPIs strip it).
RewriteCond %{HTTP:Authorization} ^(.+)$
RewriteRule .* - [E=HTTP_AUTHORIZATION:%1]

# --- Handle routes with a NON-numeric id segment (object_kind). These must precede the
#     generic numeric rules below. The (object_kind, object_id) handle is the canonical
#     resource id across the graph/attribute surface (maludb_core 0.85.0+). ---

# /v1/objects/<kind>/<id>  ->  objects_id.php?kind=<kind>&id=<id>
RewriteRule ^v1/objects/([a-zA-Z_][a-zA-Z0-9_-]*)/([0-9]+)$ \
            v1/objects_id.php?kind=$1&id=$2 [QSA,L]

# /v1/objects/<kind>       ->  objects.php?kind=<kind>   (atomic create)
RewriteRule ^v1/objects/([a-zA-Z_][a-zA-Z0-9_-]*)$ \
            v1/objects.php?kind=$1 [QSA,L]

# /v1/graph/<op>  ->  graph_<op>.php   (graph traversal ops: neighbors, walk). The op segment
# is non-numeric, so it precedes the generic numeric rules below (which would not match it).
RewriteRule ^v1/graph/([a-zA-Z_][a-zA-Z0-9_-]*)$ \
            v1/graph_$1.php [QSA,L]

# /v1/memory/<op>  ->  memory_<op>.php   (memory pipeline: config, documents, search).
RewriteRule ^v1/memory/([a-zA-Z_][a-zA-Z0-9_-]*)$ \
            v1/memory_$1.php [QSA,L]

# 4-segment: /v1/<a>/<id>/<b>/<id>  ->  <a>_id_<b>_id.php?id=...&sub_id=...
RewriteRule ^v1/([a-zA-Z][a-zA-Z0-9-]*)/([0-9]+)/([a-zA-Z][a-zA-Z0-9-]*)/([0-9]+)$ \
            v1/$1_id_$3_id.php?id=$2&sub_id=$4 [QSA,L]

# 3-segment: /v1/<a>/<id>/<b>  ->  <a>_id_<b>.php?id=...
RewriteRule ^v1/([a-zA-Z][a-zA-Z0-9-]*)/([0-9]+)/([a-zA-Z][a-zA-Z0-9-]*)$ \
            v1/$1_id_$3.php?id=$2 [QSA,L]

# 2-segment: /v1/<a>/<id>  ->  <a>_id.php?id=...
RewriteRule ^v1/([a-zA-Z][a-zA-Z0-9-]*)/([0-9]+)$ \
            v1/$1_id.php?id=$2 [QSA,L]

# 1-segment: /v1/<a>  ->  <a>.php
RewriteRule ^v1/([a-zA-Z][a-zA-Z0-9-]*)$ \
            v1/$1.php [QSA,L]
